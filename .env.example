# React Perf Profiler - Environment Variables

# Development Settings
NODE_ENV=development
VITE_DEV_MODE=true

# Extension Settings
VITE_EXTENSION_ID=your-extension-id
VITE_EXTENSION_NAME="React Perf Profiler"

# Debug Settings (set to 'true' to enable verbose logging)
DEBUG_PROFILER=false
DEBUG_BRIDGE=false

# Feature Flags
VITE_ENABLE_TIMELINE=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_CLOUD_SYNC=false

# API Settings (for future cloud features)
# VITE_API_URL=https://api.example.com
# VITE_API_KEY=your-api-key

# Cloud Sync Settings
VITE_CLOUD_SYNC_ENABLED=false
VITE_CLOUD_PROVIDER=local
# Supported providers: local, s3, gcs, dropbox, onedrive

# S3-Compatible Storage (for cloud sync)
# VITE_S3_ENDPOINT=https://s3.amazonaws.com
# VITE_S3_BUCKET=react-perf-profiles
# VITE_S3_REGION=us-east-1
# VITE_S3_ACCESS_KEY_ID=your-access-key
# VITE_S3_SECRET_ACCESS_KEY=your-secret-key

# Google Cloud Storage (for cloud sync)
# VITE_GCS_BUCKET=react-perf-profiles
# VITE_GCS_PROJECT_ID=your-project-id

# Dropbox Integration (for cloud sync)
# VITE_DROPBOX_APP_KEY=your-dropbox-app-key
# VITE_DROPBOX_FOLDER=/React Perf Profiles

# OneDrive Integration (for cloud sync)
# VITE_ONEDRIVE_CLIENT_ID=your-onedrive-client-id
# VITE_ONEDRIVE_FOLDER=/React Perf Profiles

# Export Settings
VITE_EXPORT_COMPRESSION_THRESHOLD=1048576
VITE_EXPORT_MAX_SIZE=104857600
VITE_ENABLE_EXPORT_SCREENSHOT=false
