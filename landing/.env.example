# ─── React Perf Profiler — Landing Page Environment Variables ────────────────
#
# Copy this file to landing/.env and fill in the values.
# landing/.env is git-ignored — never commit real keys.
#
# Only VITE_* variables are exposed to the browser bundle.
# All others are build-time only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email capture (pick ONE of the options below) ────────────────────────────

# Option A — Formspree (free tier, no server required)
# 1. Create a form at https://formspree.io
# 2. Copy the form ID from the URL (e.g. "xpznkgvr")
# VITE_FORMSPREE_ID=xpznkgvr

# Option B — Custom endpoint (Resend edge function, ConvertKit API, etc.)
# The endpoint must accept: POST { email: string, source: string }
# VITE_EMAIL_ENDPOINT=https://your-api.com/subscribe

# ── Analytics (optional) ─────────────────────────────────────────────────────

# Plausible (privacy-friendly, no cookies)
# VITE_PLAUSIBLE_DOMAIN=react-perf-profiler.dev

# ── Download URLs (optional override) ────────────────────────────────────────

# Override the default relative paths for the extension ZIPs.
# Use this when hosting ZIPs on a CDN (e.g. GitHub Releases assets).
# VITE_CHROME_DOWNLOAD_URL=https://github.com/rejisterjack/react-perf-profiler/releases/latest/download/react-perf-profiler-chrome.zip
# VITE_FIREFOX_DOWNLOAD_URL=https://github.com/rejisterjack/react-perf-profiler/releases/latest/download/react-perf-profiler-firefox.zip

# ── Site URL (used for OG tags and canonical links) ──────────────────────────

# VITE_SITE_URL=https://rejisterjack.github.io/react-perf-profiler
