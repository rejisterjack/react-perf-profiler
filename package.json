{
  "name": "react-perf-profiler",
  "version": "1.0.0",
  "description": "Chrome DevTools extension for profiling React performance",
  "type": "module",
  "packageManager": "pnpm@8.14.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "tsc && vite build --mode development",
    "build:firefox": "tsc && vite build --config vite.config.firefox.ts",
    "build:firefox:dev": "tsc && vite build --config vite.config.firefox.ts --mode development",
    "build:all": "pnpm run build && pnpm run build:firefox",
    "analyze": "vite build --mode analyze",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.0.0",
    "d3": "^7.8.5",
    "immer": "^10.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reselect": "^5.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/chrome": "^0.0.254",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^23.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
