{
  "name": "react-perf-profiler",
  "version": "1.0.0",
  "description": "Chrome DevTools extension for profiling React performance",
  "type": "module",
  "packageManager": "pnpm@8.14.0",
  "bin": {
    "perf-check": "./scripts/perf-check-run.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "tsc && vite build --mode development",
    "build:firefox": "tsc && vite build --config vite.config.firefox.ts",
    "build:firefox:dev": "tsc && vite build --config vite.config.firefox.ts --mode development",
    "build:all": "pnpm run build && pnpm run build:firefox",
    "build:cli": "tsc -p tsconfig.cli.json",
    "analyze": "vite build --mode analyze",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "format": "biome format src --write",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "landing:dev": "cd landing && pnpm dev",
    "landing:build": "cd landing && pnpm build",
    "landing:preview": "cd landing && pnpm preview",
    "landing:zip": "node landing/scripts/build-extension-zips.mjs",
    "perf:check": "tsx src/cli/perf-check.ts",
    "perf:check:bundles": "tsx src/cli/perf-check.ts --check-bundles",
    "perf:check:coverage": "tsx src/cli/perf-check.ts --check-coverage",
    "perf:check:all": "tsx src/cli/perf-check.ts --check-bundles --check-coverage --pr-comment",
    "prepare": "sh scripts/install-hooks.sh"
  },
  "dependencies": {
    "@react-three/fiber": "^8.15.0",
    "@tanstack/react-virtual": "^3.0.0",
    "@tensorflow/tfjs": "^4.10.0",
    "d3": "^7.8.5",
    "focus-trap": "^8.0.1",
    "focus-trap-react": "^12.0.0",
    "immer": "^10.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reselect": "^5.0.0",
    "three": "^0.158.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.0",
    "@biomejs/biome": "^1.5.3",
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/chrome": "^0.0.254",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/simple-peer": "9.11.8",
    "@types/three": "^0.158.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "axe-core": "^4.11.1",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
