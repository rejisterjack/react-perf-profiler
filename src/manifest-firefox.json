{
  "manifest_version": 2,
  "name": "React Perf Profiler",
  "version": "1.0.0",
  "description": "Firefox DevTools extension for profiling React performance",
  "author": "React Perf Profiler Team",
  "homepage_url": "https://github.com/react-perf-profiler/react-perf-profiler",
  "permissions": ["activeTab", "tabs", "<all_urls>"],
  "optional_permissions": ["clipboardWrite"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "devtools_page": "devtools.html",
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "React Perf Profiler",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": ["bridge.js", "injected.js", "panel.html", "panel.js"],
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
